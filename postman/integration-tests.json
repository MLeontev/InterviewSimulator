                  "        pm.expect(s).to.have.property(\"id\").that.is.a(\"string\");",
                  "        pm.expect(s).to.have.property(\"status\").that.is.a(\"string\");",
                  "    });",
                  "});",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{API_URL}}/api/v1/interview-sessions/candidate/{{candidateId}}",
              "host": ["{{API_URL}}"],
              "path": [
                "api",
                "v1",
                "interview-sessions",
                "candidate",
                "{{candidateId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Finish Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Корректный статус\", () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([204, 422, 404]);",
                  "});",
                  "",
                  "pm.test(\"Проверка ошибки SESSION_NOT_ACTIVE\", () => {",
                  "    if (pm.response.code === 422) {",
                  "        const json = pm.response.json();",
                  "        pm.expect(json).to.have.property(\"code\", \"SESSION_NOT_ACTIVE\");",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Проверка ошибки SESSION_NOT_FOUND\", () => {",
                  "    if (pm.response.code === 404) {",
                  "        const json = pm.response.json();",
                  "        pm.expect(json).to.have.property(\"code\", \"SESSION_NOT_FOUND\");",
                  "    }",
                  "});",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{API_URL}}/api/v1/interview-sessions/{{sessionId}}/finish",
              "host": ["{{API_URL}}"],
              "path": [
                "api",
                "v1",
                "interview-sessions",
                "{{sessionId}}",
                "finish"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Код ответа 204 или 404\", () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([204, 404]);",
                  "});",
                  "",
                  "pm.test(\"Проверка ошибки SESSION_NOT_FOUND\", () => {",
                  "    if (pm.response.code === 404) {",
                  "        const json = pm.response.json();",
                  "        pm.expect(json).to.have.property(\"code\", \"SESSION_NOT_FOUND\");",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Проверка пустого тела ответа при удалении\", () => {",
                  "    if (pm.response.code === 204) {",
                  "        pm.expect(pm.response.text()).to.be.empty;",
                  "    }",
                  "});",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
