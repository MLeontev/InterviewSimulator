@baseUrl = http://localhost:5258
@presetId = 00000005-0000-0000-0000-000000000001
@candidateId = 11111111-1111-1111-1111-111111111111

### 1) Optional: list presets
GET {{baseUrl}}/api/v1/interview-presets
Accept: application/json

### 2) Generate questions directly (without creating interview session)
GET {{baseUrl}}/api/v1/interview-presets/{{presetId}}/questions?theoryQuestions=4&codingTasks=2
Accept: application/json

### 3) Create interview session (change candidateId if active session already exists)
POST {{baseUrl}}/api/v1/interview-sessions
Content-Type: application/json
Accept: application/json

{
  "candidateId": "{{candidateId}}",
  "interviewPresetId": "{{presetId}}"
}

> {%
    client.test("Create session: status is 201", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status);
    });
    client.global.set("sessionId", response.body.sessionId);
%}

### 4) Get created session and capture first question id
GET {{baseUrl}}/api/v1/interview-sessions/{{sessionId}}
Accept: application/json

> {%
    client.test("Session has question ids", function() {
        client.assert(response.body.questionIds && response.body.questionIds.length > 0, "No questionIds in response");
    });
    client.global.set("questionId", response.body.questionIds[0]);
%}

### 5) Get first question by id
GET {{baseUrl}}/api/v1/interview-questions/{{questionId}}
Accept: application/json
